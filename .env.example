# Recommended for local dev: OpenRouter (Anthropic-compatible Messages API).
# Keys look like sk-or-v1-... — NOT the same as OpenAI (sk-proj-...).
# https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Optional: direct Anthropic when you have credits (sk-ant-...).
# If both keys are set, OpenRouter is used unless you set LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=

# Optional: force "openrouter" or "anthropic" (otherwise auto: OpenRouter key wins if set).
# LLM_PROVIDER=

# Optional: max output tokens per model call (default 2048). Lower if OpenRouter returns 402.
# LLM_MAX_TOKENS=1536
